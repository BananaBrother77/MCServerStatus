{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mcserverstatus",
  "main": "_worker.js",
  "compatibility_date": "2026-04-06",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "not_found_handling": "none"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}